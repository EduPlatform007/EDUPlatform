    'Кестенің тақырыбын белгілеу үшін қандай тег қолданылады?': 'Какой тег используется для обозначения заголовка таблицы?',
    'Нумерацияланған тізімді қандай тег құрады?': 'Какой тег создает нумерованный список?',
    
    // Урок 4
    'CSS қысқартуының толық ашылуы?': 'Полная расшифровка аббревиатуры CSS?',
    'CSS-те мәтіннің түсін өзгерту үшін қандай қасиет қолданылады?': 'Какое свойство используется для изменения цвета текста в CSS?',
    'CSS-ті HTML-ге қосудың ДҰРЫС ЕМЕС әдісі?': 'Какой способ добавления CSS в HTML является НЕПРАВИЛЬНЫМ?',
    'Келесі код қандай элементтерге стиль қолданады: .highlight { color: yellow; }?': 'К каким элементам применяется стиль в следующем коде: .highlight { color: yellow; }?',
    
    // Урок 8 - Позиционирование
    'CSS-те қандай позициялау типтері бар?': 'Какие типы позиционирования существуют в CSS?',
    'position: absolute қасиеті бар элемент нені орынға келтіреді?': 'Относительно чего позиционируется элемент с position: absolute?',
    'Келесі элементтердің қайсысы скролл кезінде өз орнында қалады?': 'Какой из следующих элементов остается на месте при прокрутке?',
    'z-index қасиеті не үшін қолданылады?': 'Для чего используется свойство z-index?',
    'position: sticky қасиеті қашан "жабысады"?': 'Когда свойство position: sticky "прилипает"?',
    'Элементтің енін орнату': 'Установка ширины элемента',
    'Элементтің орнын x және y осьтерінде анықтау': 'Определение положения элемента по осям x и y',
    'Элементтердің қабаттасу ретін анықтау': 'Определение порядка наложения элементов',
    'Элементті зум деңгейін орнату': 'Установка уровня масштабирования элемента',
    
    // Общие вопросы и заголовки
    'Білімді тексеру': 'Проверка знаний',
    'Тапсырма:': 'Задание:',
    'Практикалық тапсырма': 'Практическое задание',
    'Бұл сұраққа жауап беріңіз:': 'Ответьте на следующий вопрос:',
    'Дұрыс жауапты таңдаңыз:': 'Выберите правильный ответ:',
    'Тексеру': 'Проверить',
    'Тестті тексеру': 'Проверить тест',
    'Жауаптар': 'Ответы',
    'Дұрыс': 'Верно',
    'Қате': 'Неверно',
    'Дұрыс жауап:': 'Правильный ответ:'
  };
  
  // Создаем объект с переводами вариантов ответов
  const optionsTranslations = {
    // Различные варианты ответов
    '<paragraph>': '<paragraph>',
    '<p>': '<p>',
    '<text>': '<text>',
    '<par>': '<par>',
    '<link>': '<link>',
    '<url>': '<url>',
    '<a>': '<a>',
    '<href>': '<href>',
    '<img>': '<img>',
    '<picture>': '<picture>',
    '<image>': '<image>',
    '<src>': '<src>',
    '<table>': '<table>',
    '<tr>': '<tr>',
    '<td>': '<td>',
    '<th>': '<th>',
    '<ul>': '<ul>',
    '<ol>': '<ol>',
    '<li>': '<li>',
    '<p attribute="value">': '<p attribute="value">',
    '<p (attribute)="value">': '<p (attribute)="value">',
    '<p "attribute"="value">': '<p "attribute"="value">',
    '<p attribute:value>': '<p attribute:value>',
    'Computer Style Sheets': 'Computer Style Sheets',
    'Cascading Style Sheets': 'Cascading Style Sheets',
    'Creative Style Sheets': 'Creative Style Sheets',
    'Colorful Style Sheets': 'Colorful Style Sheets',
    'text-color': 'text-color',
    'font-color': 'font-color',
    'color': 'color',
    'text-style': 'text-style',
    'Сыртқы CSS файлын <link> тегі арқылы қосу': 'Добавление внешнего CSS файла через тег <link>',
    '<style> тегін <head> ішінде қолдану': 'Использование тега <style> внутри <head>',
    'HTML элементінде style атрибутын қолдану': 'Использование атрибута style в HTML элементе',
    'CSS кодын <css> тегтерінің ішіне жазу': 'Написание CSS кода внутри тегов <css>',
    'highlight ID-і бар элементке': 'К элементу с ID highlight',
    'highlight класы бар барлық элементтерге': 'Ко всем элементам с классом highlight',
    'highlight тегі бар элементтерге': 'К элементам с тегом highlight',
    'highlight атрибуты бар элементтерге': 'К элементам с атрибутом highlight',
    'Иә': 'Да',
    'Жоқ': 'Нет',
    'Әрқашан': 'Всегда',
    'Тышқанды үстіне әкелгенде': 'При наведении мыши',
    'Скролл кезінде белгіленген шекке жеткенде': 'При достижении заданного порога во время прокрутки',
    'Парақты жүктеген кезде': 'При загрузке страницы',
    'Құжат ағынындағы өз орнына': 'На своем месте в потоке документа',
    'Браузер терезесіне': 'Относительно окна браузера',
    'Ең жақын орналасқан (static емес) ата-элементке': 'Относительно ближайшего родительского элемента (не static)',
    'Парақтың жоғарғы жағына': 'Относительно верхней части страницы',
    'position: relative': 'position: relative',
    'position: static': 'position: static',
    'position: absolute': 'position: absolute',
    'position: fixed': 'position: fixed'
  };
  
  // Ищем все заголовки
  const headers = document.querySelectorAll('h2, h3, h4');
  headers.forEach(header => {
    const originalText = header.textContent;
    if (quizTranslations[originalText]) {
      header.textContent = quizTranslations[originalText];
    }
  });
  
  // Ищем все вопросы тестов и задания
  const quizQuestions = document.querySelectorAll('.quiz p strong, .task p strong');
  quizQuestions.forEach(questionElement => {
    const originalText = questionElement.textContent;
    if (quizTranslations[originalText]) {
      questionElement.textContent = quizTranslations[originalText];
    }
  });
  
  // Ищем все варианты ответов
  const quizOptions = document.querySelectorAll('.quiz label');
  quizOptions.forEach(optionElement => {
    const originalText = optionElement.textContent.trim();
    // Получаем текст без input (вырезаем начало с пробелом)
    const textWithoutInput = originalText.replace(/^\s*/, '');
    
    if (optionsTranslations[textWithoutInput]) {
      // Сохраняем input элемент
      const inputElement = optionElement.querySelector('input');
      // Заменяем текст на перевод
      optionElement.innerHTML = '';
      optionElement.appendChild(inputElement);
      optionElement.appendChild(document.createTextNode(' ' + optionsTranslations[textWithoutInput]));
    }
  });
  
  // Переводим кнопки
  const buttons = document.querySelectorAll('button');
  buttons.forEach(button => {
    const originalText = button.textContent.trim();
    if (quizTranslations[originalText]) {
      button.textContent = quizTranslations[originalText];
    }
  });
  
  // Переводим элементы списков заданий
  const listItems = document.querySelectorAll('.task ol li, .task ul li');
  listItems.forEach(item => {
    const originalText = item.textContent.trim();
    if (quizTranslations[originalText]) {
      item.textContent = quizTranslations[originalText];
    }
  });
}

// Модифицируем функцию loadLesson для вызова комплексного перевода
function loadLesson(num, courseType = 'html') {
  const emptyMessage = document.getElementById('empty-message');
  const loadedLesson = document.getElementById('loaded-lesson');
  const lessonData = document.getElementById('lesson-data');
  const homeworkSection = document.getElementById('homework-section');
  
  if (emptyMessage && loadedLesson && lessonData) {
    emptyMessage.style.display = 'none';
    loadedLesson.style.display = 'block';
    
    // Получаем данные урока в зависимости от типа курса
    let lessonContent;
    let homeworkContent;
    
    // Получаем текущий язык пользователя
    const userData = JSON.parse(localStorage.getItem('currentUser') || '{}');
    const lang = userData.language || 'kk';
    
    // Выбираем контент в зависимости от языка
    if (lang === 'ru' && courseType === 'html') {
      // Русский контент для HTML курса
      if (lessonsRu[num]) {
        lessonContent = lessonsRu[num].content || '';
        homeworkContent = lessonsRu[num].practiceTask || '';
      } else {
        // Если нет русского перевода для этого урока, используем казахский
        lessonContent = lessons[num]?.content || '';
        homeworkContent = lessons[num]?.practiceTask || '';
      }
    } else if (courseType === 'python') {
      lessonContent = lessons[num]?.content || '';
      homeworkContent = lessons[num]?.practiceTask || '';
    } else if (courseType === 'database') {
      lessonContent = dbLessons[num]?.content || '';
      homeworkContent = dbLessons[num]?.practiceTask || '';
    } else {
      // Казахский контент для HTML курса
      lessonContent = lessons[num]?.content || '';
      homeworkContent = lessons[num]?.practiceTask || '';
    }
    
    lessonData.innerHTML = lessonContent;
    
    // Активируем подсветку синтаксиса для кода
    document.querySelectorAll('pre code').forEach((el) => {
      if (typeof hljs !== 'undefined') {
        hljs.highlightElement(el);
      }
    });
    
    // Проверяем, есть ли домашнее задание
    if (homeworkContent && homeworkSection) {
      homeworkSection.style.display = 'block';
      const homeworkTask = document.getElementById('homework-task');
      if (homeworkTask) {
        homeworkTask.innerHTML = homeworkContent;
      }
    } else if (homeworkSection) {
      homeworkSection.style.display = 'none';
    }
    
    // Обновляем видимость видео на основе языка
    setTimeout(updateVideos, 100);
    
    // Применяем комплексный перевод, если язык русский
    if (lang === 'ru') {
      setTimeout(function() {
        if (typeof applyFullTranslation === 'function') {
          applyFullTranslation(lang);
        } else {
          console.error('Функция applyFullTranslation не найдена!');
        }
      }, 200);
    }
    
    // Вызываем пользовательское событие о загрузке урока
    if (typeof window.triggerLessonLoaded === 'function') {
      window.triggerLessonLoaded();
    }
    
    // Сохраняем номер открытого урока
    localStorage.setItem('lastOpenedLesson', num);
    localStorage.setItem('lastOpenedCourse', courseType);
  }
}

// Модифицируем обработчик события изменения языка
document.addEventListener('DOMContentLoaded', function() {
  // При изменении языка обновляем все переводы
  const langSelect = document.getElementById('select');
  if (langSelect) {
    langSelect.addEventListener('change', function() {
      const newLanguage = this.value === 'Қазақша' ? 'kk' : 'ru';
      
      // Обновляем язык в localStorage
      const userData = JSON.parse(localStorage.getItem('currentUser') || '{}');
      userData.language = newLanguage;
      localStorage.setItem('currentUser', JSON.stringify(userData));
      
      // Обновляем уроки в сайдбаре
      initLessons();
      
      // Если открыт урок, перезагружаем его с новым языком
      const currentLessonNum = localStorage.getItem('lastOpenedLesson');
      if (currentLessonNum && typeof loadLesson === 'function') {
        loadLesson(parseInt(currentLessonNum));
      } else {
        // Если урок не открыт, переводим интерфейс без перезагрузки урока
        if (newLanguage === 'ru') {
          setTimeout(function() {
            translateSidebar(newLanguage);
            // Переводим сообщение "Выберите урок"
            const emptyMessage = document.getElementById('empty-message');
            if (emptyMessage) {
              const header = emptyMessage.querySelector('h2');
              if (header && header.textContent === 'Сабақ таңдаңыз') {
                header.textContent = 'Выберите урок';
              }
              
              const paragraph = emptyMessage.querySelector('p');
              if (paragraph && paragraph.textContent === 'Сол жақтан сабақ таңдап, оқуды бастай аласыз.') {
                paragraph.textContent = 'Выберите урок слева, чтобы начать обучение.';
              }
            }
          }, 100);
        }
      }
    });
  }
});

// Обновление видеоэлементов в соответствии с языком
function updateVideos() {
  const userData = JSON.parse(localStorage.getItem('currentUser') || '{}');
  const lang = userData.language || 'kk';
  
  const videoContainers = document.querySelectorAll('.video-wrapper');
  if (videoContainers && videoContainers.length > 0) {
    videoContainers.forEach(container => {
      const kazkakhVideo = container.querySelector('[data-lang="kk"]');
      const russianVideo = container.querySelector('[data-lang="ru"]');
      
      if (kazkakhVideo && russianVideo) {
        if (lang === 'kk') {
          kazkakhVideo.style.display = 'block';
          russianVideo.style.display = 'none';
        } else {
          kazkakhVideo.style.display = 'none';
          russianVideo.style.display = 'block';
        }
      }
    });
  }
}