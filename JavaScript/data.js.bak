// Модифицируем существующую функцию для перевода тестов
function translateQuizQuestions(lang) {
  if (lang !== 'ru') return; // Нет необходимости переводить казахские тексты
  
  // Создаем объект с переводами вопросов
  const quizTranslations = {
    // Урок 2
    'HTML-де абзацты белгілеу үшін қандай тег қолданылады?': 'Какой тег используется для обозначения абзаца в HTML?',
